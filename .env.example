# Copy this file to `.env` for local development or use these variables
# directly in your hosting provider for staging/production.

# App runtime
# Use `development` locally and `production` in deployed environments.
NODE_ENV=development

# Backend server
# Local default is 3000. In production your platform may inject this automatically.
SERVER_PORT=3000

# Frontend runtime
# Public frontend URLs for API requests and websocket connections.
APP_API_BASE_URL=http://localhost:3000
APP_WS_BASE_URL=ws://localhost:3000/plan/

# Sessions
# Use a long random string in every environment. Never commit the real value.
SESSION_SECRET=replace-with-a-long-random-secret

# Client app origin
# Comma-separated list for CORS, for example:
# CLIENT_URL=http://localhost:4200,https://your-frontend.example.com
CLIENT_URL=http://localhost:4200,http://localhost:3000

# PostgreSQL
# Local example values are below. Replace them with real credentials in each environment.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=planit_poker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-db-password
