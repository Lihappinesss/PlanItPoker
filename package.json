{
  "name": "@planit-poker/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:front": "nx serve front",
    "dev:server": "nx serve server",
    "build:front": "nx build front",
    "build:server": "nx build server",
    "build": "nx run-many -t build --projects=front,server",
    "migrate": "ts-node --project apps/server/tsconfig.json apps/server/src/scripts/migrate.ts",
    "start": "node dist/apps/server/main.js"
  },
  "private": true,
  "nohoist": [
    "**/styled-jsx",
    "**/styled-jsx/**"
  ],
  "dependencies": {
    "@nrwl/express": "^17.1.2",
    "@nx/eslint-plugin": "^19.1.1"
  },
  "devDependencies": {
    "@nx/express": "17.1.2",
    "@nx/jest": "17.1.2",
    "@nx/js": "17.1.2",
    "@nx/node": "17.1.2",
    "@nx/webpack": "^17.1.2",
    "@nx/workspace": "17.1.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express-session": "^1.19.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "nx": "17.1.1",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "url-loader": "^4.1.1"
  },
  "workspaces": [
    "apps/*"
  ]
}
